+/**
+ * K-Means 算法：将 RGB 颜色数组聚类精简到 K 个色彩中心
+ */
+function kmeansQuantizeColors(rgbArray, k = 20, maxIterations = 10) {
+    if (!rgbArray || rgbArray.length === 0) return [];
+    if (rgbArray.length <= k) return rgbArray;
+
+    let centroids = [];
+    // 随机选择 K 个初始质心
+    const step = Math.floor(rgbArray.length / k);
+    for (let i = 0; i < k; i++) {
+        centroids.push([...rgbArray[i * step]]);
+    }
+
+    for (let iter = 0; iter < maxIterations; iter++) {
+        const clusters = Array.from({ length: k }, () => []);
+
+        // 分配到最近质心
+        for (let i = 0; i < rgbArray.length; i++) {
+            const pixel = rgbArray[i];
+            let minDistance = Infinity;
+            let closestIdx = 0;
+
+            for (let c = 0; c < k; c++) {
+                const dist = Math.hypot(
+                    pixel[0] - centroids[c][0],
+                    pixel[1] - centroids[c][1],
+                    pixel[2] - centroids[c][2]
+                );
+                if (dist < minDistance) {
+                    minDistance = dist;
+                    closestIdx = c;
+                }
+            }
+            clusters[closestIdx].push(pixel);
+        }
+
+        // 重新计算质心
+        let moved = false;
+        for (let c = 0; c < k; c++) {
+            if (clusters[c].length === 0) continue;
+            let sumR = 0, sumG = 0, sumB = 0;
+            for (let p of clusters[c]) {
+                sumR += p[0];
+                sumG += p[1];
+                sumB += p[2];
+            }
+            const avgR = Math.round(sumR / clusters[c].length);
+            const avgG = Math.round(sumG / clusters[c].length);
+            const avgB = Math.round(sumB / clusters[c].length);
+
+            if (avgR !== centroids[c][0] || avgG !== centroids[c][1] || avgB !== centroids[c][2]) {
+                centroids[c] = [avgR, avgG, avgB];
+                moved = true;
+            }
+        }
+
+        if (!moved) break;
+    }
+
+    // 将原图片中的每个颜色映射为其所属集群的质心颜色
+    return rgbArray.map(pixel => {
+        let minDistance = Infinity;
+        let closestCentroid = centroids[0];
+        for (let c = 0; c < k; c++) {
+            const dist = Math.hypot(
+                pixel[0] - centroids[c][0],
+                pixel[1] - centroids[c][1],
+                pixel[2] - centroids[c][2]
+            );
+            if (dist < minDistance) {
+                minDistance = dist;
+                closestCentroid = centroids[c];
+            }
+        }
+        return closestCentroid;
+    });
+}
